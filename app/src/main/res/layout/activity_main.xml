<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="#000000" android:padding="12dp">
    
    <TextView android:id="@+id/tvTimer" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Обновление через: 80с" android:textColor="#4CAF50" android:textSize="12sp" android:gravity="right" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="3" android:layout_marginTop="10dp" android:layout_marginBottom="15dp">
        <LinearLayout android:id="@+id/layoutGold" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="?attr/selectableItemBackground">
            <ImageView android:layout_width="70dp" android:layout_height="70dp" android:src="@drawable/ic_gold"/><TextView android:id="@+id/tvGoldPrice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textColor="#FFD700" android:textStyle="bold" />
        </LinearLayout>
        <LinearLayout android:id="@+id/layoutSilver" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="?attr/selectableItemBackground">
            <ImageView android:layout_width="70dp" android:layout_height="70dp" android:src="@drawable/ic_silver"/><TextView android:id="@+id/tvSilverPrice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textColor="#C0C0C0" android:textStyle="bold" />
        </LinearLayout>
        <LinearLayout android:id="@+id/layoutBtc" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="?attr/selectableItemBackground">
            <ImageView android:layout_width="70dp" android:layout_height="70dp" android:src="@drawable/ic_bitcoin"/><TextView android:id="@+id/tvBitcoinPrice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textColor="#F7931A" android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <com.github.mikephil.charting.charts.LineChart android:id="@+id/lineChart" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:layout_marginVertical="10dp">
        <Button android:id="@+id/btn1W" android:layout_width="60dp" android:layout_height="40dp" android:text="1W" android:textSize="10sp" android:layout_margin="2dp" android:backgroundTint="#222222"/>
        <Button android:id="@+id/btn1M" android:layout_width="60dp" android:layout_height="40dp" android:text="1M" android:textSize="10sp" android:layout_margin="2dp" android:backgroundTint="#222222"/>
        <Button android:id="@+id/btn1Y" android:layout_width="60dp" android:layout_height="40dp" android:text="1Y" android:textSize="10sp" android:layout_margin="2dp" android:backgroundTint="#222222"/>
        <Button android:id="@+id/btn5Y" android:layout_width="60dp" android:layout_height="40dp" android:text="5Y" android:textSize="10sp" android:layout_margin="2dp" android:backgroundTint="#222222"/>
    </LinearLayout>

    <Button android:id="@+id/btnRefresh" android:layout_width="match_parent" android:layout_height="50dp" android:text="ОБНОВИТЬ СЕЙЧАС" android:backgroundTint="#1B5E20" />
    <TextView android:id="@+id/tvStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Кэш активен" android:textColor="#555555" android:gravity="center" android:layout_marginTop="5dp" android:textSize="10sp"/>
</LinearLayout>
