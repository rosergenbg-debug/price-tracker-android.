<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="#000000" android:padding="12dp">
    
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="МОНИТОР РЫНКА (EUR/KG)" android:textColor="#FFFFFF" android:textSize="18sp" android:gravity="center" android:layout_marginTop="10dp" android:layout_marginBottom="20dp" android:textStyle="bold" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="3" android:layout_marginBottom="20dp">
        
        <LinearLayout android:id="@+id/layoutGold" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="75dp" android:layout_height="75dp" android:src="@drawable/ic_gold" android:scaleType="fitCenter"/>
            <TextView android:id="@+id/tvGoldPrice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textColor="#FFD700" android:textSize="16sp" android:textStyle="bold" />
        </LinearLayout>
        
        <LinearLayout android:id="@+id/layoutSilver" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="75dp" android:layout_height="75dp" android:src="@drawable/ic_silver" android:scaleType="fitCenter"/>
            <TextView android:id="@+id/tvSilverPrice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textColor="#C0C0C0" android:textSize="16sp" android:textStyle="bold" />
        </LinearLayout>
        
        <LinearLayout android:id="@+id/layoutBtc" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="75dp" android:layout_height="75dp" android:src="@drawable/ic_bitcoin" android:scaleType="fitCenter"/>
            <TextView android:id="@+id/tvBitcoinPrice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textColor="#F7931A" android:textSize="16sp" android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <com.github.mikephil.charting.charts.LineChart android:id="@+id/lineChart" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:layout_marginBottom="10dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="10dp">
        <Button android:id="@+id/btn1W" android:layout_width="60dp" android:layout_height="40dp" android:text="1W" android:textSize="10sp" android:layout_margin="2dp" android:backgroundTint="#222222" />
        <Button android:id="@+id/btn1M" android:layout_width="60dp" android:layout_height="40dp" android:text="1M" android:textSize="10sp" android:layout_margin="2dp" android:backgroundTint="#222222" />
        <Button android:id="@+id/btn1Y" android:layout_width="60dp" android:layout_height="40dp" android:text="1Y" android:textSize="10sp" android:layout_margin="2dp" android:backgroundTint="#222222" />
        <Button android:id="@+id/btn5Y" android:layout_width="60dp" android:layout_height="40dp" android:text="5Y" android:textSize="10sp" android:layout_margin="2dp" android:backgroundTint="#222222" />
    </LinearLayout>

    <Button android:id="@+id/btnRefresh" android:layout_width="match_parent" android:layout_height="55dp" android:text="ОБНОВИТЬ ВСЁ" android:textSize="16sp" android:textStyle="bold" android:backgroundTint="#1B5E20" />
    <TextView android:id="@+id/tvStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Система готова" android:textColor="#555555" android:gravity="center" android:layout_marginTop="5dp" android:textSize="11sp"/>
</LinearLayout>
