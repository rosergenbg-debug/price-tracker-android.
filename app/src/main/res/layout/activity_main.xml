<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="#000000">
    <LinearLayout android:id="@+id/header" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="10dp" android:gravity="center">
        <LinearLayout android:id="@+id/layoutGold" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="60dp" android:layout_height="60dp" android:src="@drawable/gold"/>
            <TextView android:id="@+id/tvGoldPrice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:text="EUR 0/kg" android:textColor="#FFD700" android:textSize="14sp" android:textStyle="bold"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/layoutSilver" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="60dp" android:layout_height="60dp" android:src="@drawable/silver"/>
            <TextView android:id="@+id/tvSilverPrice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:text="EUR 0/kg" android:textColor="#C0C0C0" android:textSize="14sp" android:textStyle="bold"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/layoutBtc" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="60dp" android:layout_height="60dp" android:src="@drawable/bitcoin"/>
            <TextView android:id="@+id/tvBitcoinPrice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="EUR 0" android:textColor="#F7931A" android:textSize="18sp" android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>
    <TextView android:id="@+id/tvTimer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/header" android:layout_alignParentEnd="true" android:layout_marginEnd="10dp" android:text="Aktualisierung: 80s" android:textColor="#AB47BC" android:textSize="12sp"/>
    <com.github.mikephil.charting.charts.LineChart android:id="@+id/lineChart" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_above="@+id/timeButtons" android:layout_below="@id/tvTimer" android:layout_margin="10dp"/>
    <LinearLayout android:id="@+id/timeButtons" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_above="@+id/btnRefresh" android:orientation="horizontal" android:padding="5dp">
        <Button android:id="@+id/btn1D" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="1D" android:backgroundTint="#AB47BC" android:textSize="12sp"/>
        <Button android:id="@+id/btn1W" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="1W" android:backgroundTint="#AB47BC" android:textSize="12sp"/>
        <Button android:id="@+id/btn1M" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="1M" android:backgroundTint="#AB47BC" android:textSize="12sp"/>
        <Button android:id="@+id/btn1Y" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="1Y" android:backgroundTint="#AB47BC" android:textSize="12sp"/>
        <Button android:id="@+id/btn3Y" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="3Y" android:backgroundTint="#AB47BC" android:textSize="12sp"/>
    </LinearLayout>
    <Button android:id="@+id/btnRefresh" android:layout_width="match_parent" android:layout_height="60dp" android:layout_alignParentBottom="true" android:layout_margin="10dp" android:backgroundTint="#1B5E20" android:text="JETZT AKTUALISIEREN" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
    <TextView android:id="@+id/tvStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_above="@id/btnRefresh" android:layout_centerHorizontal="true" android:text="Warten..." android:textColor="#757575" android:textSize="10sp"/>
</RelativeLayout>
